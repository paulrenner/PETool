  s = s & "    Next i" & vbCrLf
  s = s & "" & vbCrLf
  s = s & "    ' Object number as 3 bytes little-endian" & vbCrLf
  s = s & "    input_data(baseLen) = objNum And &HFF" & vbCrLf
