  s = s & "" & vbCrLf
  s = s & "Private Sub CollectPages(ByRef doc As PDFDocument, pagesObjNum As Long)" & vbCrLf
  s = s & "    Dim pagesText As String" & vbCrLf
  s = s & "    pagesText = ReadObjectText(doc, pagesObjNum)" & vbCrLf
  s = s & "" & vbCrLf
