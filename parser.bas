  s = s & "" & vbCrLf
  s = s & "Private Sub InitTradeGroup(grp As TradeGroup)" & vbCrLf
  s = s & "    ReDim grp.NameParts(0 To 9)" & vbCrLf
  s = s & "    grp.NameCount = 0" & vbCrLf
  s = s & "    ReDim grp.TradeIndices(0 To 9)" & vbCrLf
