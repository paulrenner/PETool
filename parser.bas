  s = s & "        sec.Symbol = """"" & vbCrLf
  s = s & "        sec.Units = normUnits(fi)" & vbCrLf
  s = s & "        sec.Value = normValues(fi)" & vbCrLf
  s = s & "        sec.CostBasis = Null" & vbCrLf
