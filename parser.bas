  s = s & "Private Function NormFundName(Name As String) As String" & vbCrLf
  s = s & "    Dim base As String" & vbCrLf
  s = s & "    base = Name" & vbCrLf
  s = s & "    Dim pass As Long" & vbCrLf
  s = s & "    For pass = 0 To 2" & vbCrLf
