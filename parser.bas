Attribute VB_Name = "PDFExtractorSetup"
Option Explicit

' PDFExtractorSetup.bas — Bootstrapper module (generated by vba/build.mjs)
' Import this single file into a new Excel workbook, then run the Setup macro.
' It will import all 9 modules and add the RegExp reference.
' After setup, this module removes itself.

Public Sub Setup()
  Dim fso As Object, tempDir As String
  Set fso = CreateObject("Scripting.FileSystemObject")

  ' Create temp directory
  tempDir = fso.BuildPath(Environ("TEMP"), "PDFExtractor_build")
  If Not fso.FolderExists(tempDir) Then fso.CreateFolder tempDir

  ' Module names and contents
  Dim modules(8) As String, contents(8) As String
  modules(0) = "PDFCrypto.bas": contents(0) = GetModule_PDFCrypto()
  modules(1) = "PDFDeflate.bas": contents(1) = GetModule_PDFDeflate()
  modules(2) = "PDFReader.bas": contents(2) = GetModule_PDFReader()
  modules(3) = "PDFTextExtract.bas": contents(3) = GetModule_PDFTextExtract()
  modules(4) = "UBSExtract.bas": contents(4) = GetModule_UBSExtract()
  modules(5) = "UBSLoanExtract.bas": contents(5) = GetModule_UBSLoanExtract()
  modules(6) = "UBSSummary.bas": contents(6) = GetModule_UBSSummary()
  modules(7) = "QPRWriter.bas": contents(7) = GetModule_QPRWriter()
  modules(8) = "PDFExtractorMain.bas": contents(8) = GetModule_PDFExtractorMain()

  ' Write .bas files to temp and import them
  Dim i As Long, filePath As String
  Dim ts As Object
  For i = 0 To UBound(modules)
    filePath = fso.BuildPath(tempDir, modules(i))
    Set ts = fso.CreateTextFile(filePath, True)
    ts.Write contents(i)
    ts.Close
    ThisWorkbook.VBProject.VBComponents.Import filePath
    fso.DeleteFile filePath, True
  Next i

  ' Clean up temp folder
  On Error Resume Next
  fso.DeleteFolder tempDir, True
  On Error GoTo 0

  ' Add reference to Microsoft VBScript Regular Expressions 5.5
  On Error Resume Next
  ThisWorkbook.VBProject.References.AddFromGuid "{3F4DACA7-160D-11D2-A8E9-00104B365C9F}", 5, 5
  On Error GoTo 0

  MsgBox "Setup complete! Imported " & (UBound(modules) + 1) & " modules." & vbCrLf & vbCrLf & _
    "Save this workbook as .xlsm, then you can delete the PDFExtractorSetup module." & vbCrLf & vbCrLf & _
    "Available macros:" & vbCrLf & _
    "  ExtractPDFText" & vbCrLf & _
    "  ExtractUBSStatement" & vbCrLf & _
    "  ExtractAndWriteQPR" & vbCrLf & _
    "  BatchExtractToQPR", _
    vbInformation, "PDFExtractor Setup"

  ' Remove this bootstrapper module
  On Error Resume Next
  ThisWorkbook.VBProject.VBComponents.Remove _
    ThisWorkbook.VBProject.VBComponents("PDFExtractorSetup")
  On Error GoTo 0
End Sub

