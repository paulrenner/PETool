End Function

Private Function GetModule_PDFDeflate() As String
  Dim s As String
  s = ""
  s = s & "Attribute VB_Name = ""PDFDeflate""" & vbCrLf
  s = s & "Option Explicit" & vbCrLf
  s = s & "" & vbCrLf
  s = s & "' Pure VBA implementation of RFC 1951 DEFLATE decompression" & vbCrLf
