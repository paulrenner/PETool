  s = s & "    input_data(baseLen + 4) = (genNum \ &H100) And &HFF" & vbCrLf
  s = s & "" & vbCrLf
  s = s & "    md5Result = MD5Hash(input_data)" & vbCrLf
  s = s & "" & vbCrLf
  s = s & "    ' Take min(baseLen + 5, 16) bytes" & vbCrLf
  s = s & "    keyLen = baseLen + 5" & vbCrLf
  s = s & "    If keyLen > 16 Then keyLen = 16" & vbCrLf
