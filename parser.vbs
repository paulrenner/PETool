  ts.WriteLine "            If InStr(1, lines(j), mCatKeys(ki)) > 0 Then"
  ts.WriteLine "                UpdateSecCategory = mCatVals(ki)"
  ts.WriteLine "                Exit For"
  ts.WriteLine "            End If"
  ts.WriteLine "        Next ki"
